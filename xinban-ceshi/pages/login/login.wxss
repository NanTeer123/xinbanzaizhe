.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1890ff 0%, #096dd9 100%);
  padding: 0;
  display: flex;
  flex-direction: column;
}

.logo-section {
  padding: 120rpx 0 60rpx;
  text-align: center;
}

.logo-container {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 30rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 24rpx;
}

.app-name {
  font-size: 56rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}

.login-section {
  flex: 1;
  background: white;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx;
}

.login-tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
}

.login-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.login-tab.active {
  background: #1890ff;
  color: white;
  font-weight: bold;
}

.login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 28rpx;
  margin: 0 0 20rpx;
  border: none;
}

.wechat-login {
  background: #07c160;
  color: white;
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-weight: 500;
}

.divider {
  display: flex;
  align-items: center;
  margin: 30rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #e8e8e8;
}

.divider-text {
  padding: 0 24rpx;
  color: #999;
  font-size: 26rpx;
}

.phone-login {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.phone-input {
  width: 100%;
  border: 2rpx solid #e8e8e8;
  border-radius: 24rpx;
  padding: 28rpx;
  font-size: 30rpx;
  background: #fafafa;
  box-sizing: border-box;
}

.phone-btn {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: white;
}

.agreement {
  margin-top: 30rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

.link {
  color: #1890ff;
}

.password-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.form-input {
  width: 100%;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 30rpx;
  background: #fafafa;
  box-sizing: border-box;
}

.password-btn {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: white;
  margin-top: 10rpx;
}

.admin-tip {
  margin-top: 30rpx;
  padding: 20rpx;
  background: #fff7e6;
  border-radius: 12rpx;
  text-align: center;
}

.tip-label {
  font-size: 26rpx;
  color: #999;
}

.tip-value {
  font-size: 26rpx;
  color: #faad14;
  font-weight: bold;
}

.switch-link {
  margin-top: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #1890ff;
}

.profile-section {
  flex: 1;
  background: white;
  border-radius: 40rpx 40rpx 0 0;
  padding: 40rpx;
}

.section-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  text-align: center;
}

.section-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 40rpx;
}

.form-container {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.form-picker {
  width: 100%;
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 30rpx;
  background: #fafafa;
  color: #333;
  box-sizing: border-box;
}

.submit-btn {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: white;
  border: none;
  border-radius: 48rpx;
  font-size: 32rpx;
  padding: 28rpx;
  margin-top: 10rpx;
}

.skip-btn {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 20rpx;
}

.copyright {
  padding: 30rpx;
  text-align: center;
  color: rgba(255,255,255,0.7);
  font-size: 24rpx;
}
