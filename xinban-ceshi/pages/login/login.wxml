<view class="container">
  <view class="logo-section">
    <view class="logo-container">
      <image class="logo" src="/images/logo.png" mode="aspectFill"></image>
    </view>
    <view class="app-name">鑫办</view>
    <view class="app-slogan">智能办公协作平台</view>
  </view>

  <view class="login-section">
    <view class="login-tabs">
      <view class="login-tab {{loginType === 'login' ? 'active' : ''}}" bindtap="switchToLogin">登录</view>
      <view class="login-tab {{loginType === 'register' ? 'active' : ''}}" bindtap="switchToRegister">注册</view>
    </view>

    <!-- 登录表单 -->
    <view wx:if="{{loginType === 'login'}}" class="form-container">
      <view class="form-item">
        <input class="form-input" placeholder="账号" value="{{username}}" bindinput="onUsernameInput" />
      </view>
      <view class="form-item">
        <input class="form-input" type="password" placeholder="密码" value="{{password}}" bindinput="onPasswordInput" />
      </view>
      <button class="submit-btn" bindtap="login" disabled="{{isLoading}}">
        {{isLoading ? '登录中...' : '登录'}}
      </button>
    </view>

    <!-- 注册表单 -->
    <view wx:if="{{loginType === 'register'}}" class="form-container">
      <view class="form-item">
        <input class="form-input" placeholder="账号" value="{{username}}" bindinput="onUsernameInput" />
      </view>
      <view class="form-item">
        <input class="form-input" type="password" placeholder="密码" value="{{password}}" bindinput="onPasswordInput" />
      </view>
      <view class="form-item">
        <input class="form-input" placeholder="姓名" value="{{name}}" bindinput="onNameInput" />
      </view>
      <view class="form-item">
        <picker mode="selector" range="{{departments}}" bindchange="onDepartmentChange">
          <view class="form-picker">{{department || '请选择所属部门'}}</view>
        </picker>
      </view>
      <button class="submit-btn" bindtap="register" disabled="{{isLoading}}">
        {{isLoading ? '注册中...' : '注册'}}
      </button>
    </view>
  </view>

  <view class="copyright">
    <text>© 2026 鑫办 智能办公平台</text>
  </view>
</view>