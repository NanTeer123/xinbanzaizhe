.container {
  padding: 0;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.page-header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 30rpx 20rpx;
  color: white;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
}

.content {
  padding: 20rpx;
}

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.clock-card {
  text-align: center;
}

.date-display {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 30rpx;
}

.time-display {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.time-item {
  flex: 1;
}

.time-label {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.time-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.time-divider {
  font-size: 36rpx;
  color: #ccc;
  margin: 0 20rpx;
}

.clock-buttons {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.clock-btn {
  width: 280rpx;
  height: 88rpx;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.clock-btn:active {
  transform: scale(0.96);
}

.clock-btn::after {
  border: none;
}

.btn-in {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.btn-out {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
}

.btn-photo {
  background: linear-gradient(135deg, #faad14 0%, #d48806 100%);
}

.status-text {
  font-size: 32rpx;
  color: #52c41a;
  font-weight: bold;
}

.apply-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #f6ffed 0%, #d9f7be 100%);
  color: #52c41a;
  border: 2rpx solid #b7eb8f;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.apply-btn::after {
  border: none;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.records-list {
  margin-top: 10rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-date {
  font-size: 28rpx;
  color: #333;
}

.record-info {
  text-align: right;
}

.record-type {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.record-time {
  font-size: 28rpx;
}

.time-in {
  color: #52c41a;
}

.time-separator {
  margin: 0 10rpx;
  color: #999;
}

.time-out {
  color: #1890ff;
}

.empty-state {
  text-align: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.form-item {
  padding: 20rpx 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-picker {
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-btn {
  margin: 30rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: white;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.submit-btn::after {
  border: none;
}