.container {
  padding: 0;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.page-header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 30rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: white;
}

.back-btn {
  font-size: 48rpx;
  font-weight: 300;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
}

.header-placeholder {
  width: 60rpx;
  height: 60rpx;
}

.content {
  padding: 20rpx;
}

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.todo-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.todo-item:last-child {
  border-bottom: none;
}

.todo-info {
  flex: 1;
}

.todo-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.todo-meta {
  font-size: 24rpx;
  color: #999;
}

.score-btn {
  padding: 12rpx 28rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: white;
  border: none;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.score-btn::after {
  border: none;
}

.empty-list {
  text-align: center;
  padding: 40rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

.score-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.score-item:last-child {
  border-bottom: none;
}

.score-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.score-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.score-stars {
  font-size: 28rpx;
  color: #faad14;
}

.score-meta {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.score-comment {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  font-weight: 300;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-info {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.modal-body {
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #f5f7fa;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #1890ff;
  background: white;
}

.form-textarea {
  height: 160rpx;
  padding: 24rpx;
}

.form-picker {
  width: 100%;
  height: 88rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  color: #333;
}

.stars-picker {
  font-size: 36rpx;
  color: #faad14;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.modal-btn::after {
  border: none;
}

.btn-cancel {
  background: #f5f7fa;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: white;
}
