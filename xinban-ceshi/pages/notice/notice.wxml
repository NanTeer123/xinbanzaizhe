<view class="container">
  <view class="page-header">
    <view class="page-title">企业公告</view>
    <view wx:if="{{userData && (userData.role === 'super_admin' || userData.role === 'dept_admin')}}" class="header-action" bindtap="showAddModal">发布公告</view>
  </view>

  <view class="content">
    <view wx:if="{{notices.length > 0}}" class="notice-list">
      <view wx:for="{{notices}}" wx:key="_id" class="notice-card">
        <view class="notice-header">
          <view class="notice-avatar">{{item.publisher ? item.publisher.charAt(0) : '?'}}</view>
          <view class="notice-info">
            <view class="notice-publisher">{{item.publisher || '系统'}}</view>
            <view class="notice-time">{{formatDate(item.createTime)}}</view>
          </view>
          <view class="notice-scope">
            <text wx:if="{{item.scope === 'all'}}">全员</text>
            <text wx:else>{{item.scope}}</text>
          </view>
        </view>
        <view class="notice-content">{{item.content}}</view>
      </view>
    </view>
    <view wx:else class="empty-state">
      <view class="empty-icon">📢</view>
      <view class="empty-text">暂无公告</view>
    </view>
  </view>

  <view class="modal" wx:if="{{showAddModal}}" bindtap="hideAddModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-title">发布公告</view>
        <view class="modal-close" bindtap="hideAddModal">×</view>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <view class="form-label">公告内容</view>
          <textarea class="form-textarea" placeholder="请输入公告内容" value="{{newNotice.content}}" bindinput="onContentInput" />
        </view>
        <view class="form-item">
          <view class="form-label">发布范围</view>
          <picker mode="selector" range="{{scopeOptions}}" bindchange="onScopeChange">
            <view class="form-picker">{{scopeLabel}}</view>
          </picker>
        </view>
      </view>
      <button class="submit-btn" bindtap="submitNotice">发布</button>
    </view>
  </view>
</view>