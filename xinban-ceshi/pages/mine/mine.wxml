<view class="container">
  <view class="page-header">
    <view class="back-btn" bindtap="goBack">‹</view>
    <view class="page-title">个人中心</view>
    <view class="header-placeholder"></view>
  </view>

  <view class="content">
    <view class="card profile-card">
      <view wx:if="{{!userData}}" class="profile-empty">
        <view class="profile-avatar">
          <text class="avatar-text">?</text>
        </view>
        <view class="profile-info">
          <view class="profile-name">完善个人信息</view>
        </view>
        <button class="profile-btn" bindtap="showProfileModal">设置信息</button>
      </view>
      <view wx:else class="profile-content">
        <view class="profile-avatar">
          <text class="avatar-text">{{userData.name ? userData.name.charAt(0) : '?'}}</text>
        </view>
        <view class="profile-info">
          <view class="profile-name">{{userData.name}}</view>
          <view class="profile-role">{{userData.role}}</view>
          <view class="profile-dept">{{userData.department || '未设置部门'}}</view>
        </view>
        <button class="profile-btn" bindtap="showProfileModal">编辑信息</button>
      </view>
    </view>

    <view class="card menu-card">
      <view class="card-title">快捷入口</view>
      <view class="menu-item" bindtap="navigateTo" data-url="/pages/attendance/attendance">
        <view class="menu-left">
          <text class="menu-icon">📋</text>
          <text class="menu-text">打卡考勤</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="navigateTo" data-url="/pages/approval/approval">
        <view class="menu-left">
          <text class="menu-icon">📝</text>
          <text class="menu-text">审批流程</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="navigateTo" data-url="/pages/task/task">
        <view class="menu-left">
          <text class="menu-icon">📌</text>
          <text class="menu-text">任务管理</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="navigateTo" data-url="/pages/score/score">
        <view class="menu-left">
          <text class="menu-icon">⭐</text>
          <text class="menu-text">评分系统</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="card about-card">
      <view class="card-title">关于</view>
      <view class="about-content">
        <text class="about-text">鑫办3 - 企业办公协作平台 v1.0</text>
      </view>
    </view>

    <view class="logout-section">
      <button class="logout-btn" bindtap="logout">退出登录</button>
    </view>
  </view>

  <view class="modal" wx:if="{{showProfileModal}}" bindtap="hideProfileModal">
    <view class="modal-content">
      <view class="modal-header">
        <view class="modal-title">个人信息</view>
        <view class="modal-close" bindtap="hideProfileModal">×</view>
      </view>
      
      <view class="modal-body">
        <view class="form-item">
          <view class="form-label">姓名</view>
          <input class="form-input" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
        </view>

        <view class="form-item">
          <view class="form-label">职位</view>
          <picker mode="selector" range="{{roles}}" value="{{roleIndex}}" bindchange="onRoleChange">
            <view class="form-picker">{{role}}</view>
          </picker>
        </view>

        <view class="form-item">
          <view class="form-label">部门</view>
          <input class="form-input" placeholder="请输入部门" value="{{department}}" bindinput="onDepartmentInput" />
        </view>
      </view>

      <view class="modal-footer">
        <button class="modal-btn btn-cancel" bindtap="hideProfileModal">取消</button>
        <button class="modal-btn btn-confirm" bindtap="saveProfile">保存</button>
      </view>
    </view>
  </view>
</view>
