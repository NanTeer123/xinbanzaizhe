.container {
  padding: 0;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.page-header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 30rpx 20rpx;
  color: white;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
}

.chat-list {
  padding: 20rpx;
}

.chat-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.chat-item:active {
  background: #f5f7fa;
}

.chat-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: white;
  margin-right: 20rpx;
}

.chat-info {
  flex: 1;
}

.chat-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.chat-last {
  font-size: 24rpx;
  color: #999;
}

.chat-time {
  font-size: 22rpx;
  color: #999;
  margin-right: 16rpx;
}

.unread-badge {
  background: #ff4d4f;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  min-width: 40rpx;
  text-align: center;
}

.chat-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #f5f7fa;
  z-index: 100;
}

.chat-header {
  background: white;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.back-btn {
  font-size: 48rpx;
  color: #333;
  font-weight: 300;
}

.chat-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.message-list {
  height: calc(100vh - 200rpx);
  padding: 20rpx;
}

.message-item {
  display: flex;
  margin-bottom: 24rpx;
}

.message-item.self {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: white;
  flex-shrink: 0;
}

.message-item.self .message-avatar {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.message-content {
  max-width: 70%;
  margin: 0 16rpx;
}

.message-text {
  background: white;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.message-item.self .message-text {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: white;
  border-radius: 24rpx;
}

.message-image {
  margin-top: 12rpx;
}

.message-image image {
  max-width: 300rpx;
  border-radius: 12rpx;
}

.message-time {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
  text-align: right;
}

.chat-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.input-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  width: 72rpx;
  height: 72rpx;
  background: #f5f7fa;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: #f5f7fa;
  border-radius: 36rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: white;
  border: none;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.send-btn::after {
  border: none;
}

.empty-state {
  text-align: center;
  padding: 60rpx 20rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}