.container {
  padding: 0;
  background-color: #f5f7fa;
  min-height: 100vh;
}

.page-header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 30rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: white;
}

.back-btn {
  font-size: 48rpx;
  font-weight: 300;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
}

.header-placeholder {
  width: 60rpx;
  height: 60rpx;
}

.content {
  padding: 20rpx;
}

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.tabs-card {
  padding: 0;
}

.tabs {
  display: flex;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #1890ff;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #1890ff;
  border-radius: 2rpx;
}

.action-bar {
  margin-bottom: 20rpx;
}

.add-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.add-btn::after {
  border: none;
}

.add-icon {
  font-size: 36rpx;
  font-weight: 300;
}

.list-container {
  padding-bottom: 20rpx;
}

.task-card {
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.task-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: bold;
}

.status-badge.in_progress {
  background: #e6f7ff;
  color: #1890ff;
}

.status-badge.completed {
  background: #f6ffed;
  color: #52c41a;
}

.status-badge.delayed {
  background: #fff1f0;
  color: #ff4d4f;
}

.task-meta {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.meta-item {
  margin-right: 10rpx;
}

.meta-divider {
  margin: 0 10rpx;
}

.task-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.task-phases {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.phase-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.phase-icon {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #d9d9d9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #d9d9d9;
  margin-right: 16rpx;
}

.phase-icon.completed {
  background: #52c41a;
  border-color: #52c41a;
  color: white;
}

.phase-name {
  font-size: 26rpx;
  color: #666;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  border: none;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.action-btn::after {
  border: none;
}

.btn-progress {
  background: #fff7e6;
  color: #faad14;
}

.btn-complete {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: white;
}

.progress-history {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.history-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.history-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f7fa;
}

.history-item:last-child {
  border-bottom: none;
}

.history-time {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.history-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.history-reason {
  font-size: 24rpx;
  color: #ff4d4f;
  margin-top: 8rpx;
}

.empty-card {
  padding: 60rpx 30rpx;
}

.empty-state {
  text-align: center;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  font-weight: 300;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.add-phase-btn {
  padding: 8rpx 24rpx;
  background: #e6f7ff;
  color: #1890ff;
  border: none;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.add-phase-btn::after {
  border: none;
}

.phase-input-item {
  margin-bottom: 16rpx;
}

.phase-input-item:last-child {
  margin-bottom: 0;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #f5f7fa;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #1890ff;
  background: white;
}

.form-textarea {
  height: 160rpx;
  padding: 24rpx;
}

.form-picker {
  width: 100%;
  height: 88rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  color: #333;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.modal-btn::after {
  border: none;
}

.btn-cancel {
  background: #f5f7fa;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: white;
}

.history-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.history-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
  object-fit: cover;
}

.image-upload {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.uploaded-image {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.uploaded-image image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.image-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.6);
  border-radius: 50%;
  color: white;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-btn {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx dashed #d9d9d9;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 48rpx;
  color: #d9d9d9;
}

.progress-modal {
  width: 680rpx;
}
